# Copy this file to `.env` in the repo root and update secrets per environment.
# Values below are safe local defaults so both apps can boot via `pnpm start:dev`.

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/okey?schema=public"

# Authn/Authz
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
RESET_TOKEN_SECRET="dev-reset-secret-change-me"

# Email (stubbed locally, configure real provider in prod)
EMAIL_FROM="no-reply@okeyscore.local"
EMAIL_API_KEY="dev-email-api-key"

# Cross-app URLs
WEB_BASE_URL="http://localhost:3000"
API_BASE_URL="http://localhost:4000"
